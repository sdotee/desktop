# Local macOS release build configuration.
# Copy to `.env` and fill in. `.env` is gitignored.
# Used by scripts/build-local.sh — NOT by the GitHub Actions workflow.

# ---- Apple Developer ----
# Team ID (10 chars). Find in developer.apple.com → Membership.
APPLE_TEAM_ID=MJRBT9FJS7

# Developer ID Application identity, exactly as it appears in
# `security find-identity -v -p codesigning`.
DEVELOPER_ID_APPLICATION="Developer ID Application: Show Corporation (MJRBT9FJS7)"

# ---- Notarization ----
# Apple ID email used for notarytool submissions.
APPLE_ID=

# App-specific password generated at appleid.apple.com (NOT your Apple ID password).
APPLE_APP_PASSWORD=

# ---- Sparkle ----
# Public EdDSA key (base64). Output of `generate_keys`.
# Injected into Info.plist at build time; do NOT commit the real key here.
SPARKLE_ED25519_PUBLIC_KEY=

# Where the DMG will be hosted. Used to build appcast <enclosure url=...>.
# Per-version GitHub Release download URL prefix.
# Example: https://github.com/<owner>/<repo>/releases/download/v1.0.2/
SPARKLE_DOWNLOAD_URL_PREFIX=https://github.com/sdotee/app/releases/download/v1.0.2/

# Optional: path to a private-key file for sign_update.
# Leave empty to let sign_update read the key from the macOS Keychain
# (the default behavior of `generate_keys`).
SPARKLE_ED25519_PRIVATE_KEY_FILE=

# ---- Build metadata ----
# Marketing version (CFBundleShortVersionString), e.g. 1.0.2
VERSION_NUMBER=1.0.2

# Build number (CFBundleVersion). Must increase across releases.
BUILD_NUMBER=1
